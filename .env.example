# =============================================
# LaptopGuru CRM — Environment Variables
# =============================================
# Copy to .env and fill in real values.
# Variables marked [REQUIRED] must be set.
# Variables marked [OPTIONAL] have defaults.

# --- Database [REQUIRED] ---
DATABASE_URL=postgresql://shorterlink:shorterlink_dev@localhost:5433/shorterlink

# --- Auth (NextAuth v5) [REQUIRED] ---
NEXTAUTH_SECRET=change-me-to-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-to-random-secret
AUTH_URL=http://localhost:3000

# --- NestJS API Auth [REQUIRED for apps/api] ---
JWT_SECRET=change-me-to-random-jwt-secret

# --- IMAP (reading incoming emails) [REQUIRED] ---
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_USER=sklep@laptopguru.pl
IMAP_PASSWORD=your-imap-password

# --- SMTP (sending emails) [REQUIRED] ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=sklep@laptopguru.pl
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=sklep@laptopguru.pl

# --- YouTube [REQUIRED for video features] ---
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_HANDLE=@your-channel

# --- App [REQUIRED] ---
APP_URL=http://localhost:3000
DOMAIN=localhost

# --- Registration [OPTIONAL] ---
INVITE_CODE=your-secret-invite-code

# --- Redis (for BullMQ queues in apps/api) [REQUIRED for apps/api] ---
REDIS_URL=redis://localhost:6379

# --- NestJS API [REQUIRED for apps/api] ---
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# --- AWS S3 (file attachments) [OPTIONAL] ---
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=shorterlink-attachments

# --- AWS S3 + MediaConvert + CloudFront (video upload) [REQUIRED for S3 videos] ---
AWS_S3_VIDEO_BUCKET=shorterlink-videos-eu-central-1
AWS_CLOUDFRONT_DOMAIN=cdn.laptopguru.pl
AWS_CLOUDFRONT_DISTRIBUTION_ID=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY_BASE64=
CLOUDFRONT_SIGNED_URL_TTL_SECONDS=14400
AWS_MEDIACONVERT_ENDPOINT=
AWS_MEDIACONVERT_ROLE_ARN=
AWS_MEDIACONVERT_QUEUE_ARN=
VIDEO_UPLOAD_MAX_BYTES=2147483648
VIDEO_PRESIGN_TTL_SECONDS=900
VIDEO_MIN_WATCH_FOR_VIEW_SECONDS=10
MEDIACONVERT_WEBHOOK_SECRET=

# --- YouTube OAuth (Upload) [REQUIRED for YouTube dual-publish] ---
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_DEFAULT_PRIVACY_STATUS=unlisted

# --- Postgres (for docker-compose) [OPTIONAL] ---
POSTGRES_USER=shorterlink
POSTGRES_PASSWORD=shorterlink_dev
POSTGRES_DB=shorterlink
